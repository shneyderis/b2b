# Postgres connection string (Supabase or local)
DATABASE_URL=postgres://user:pass@localhost:5432/winery

# JWT
JWT_SECRET=change-me

# Telegram (outbound only — no webhook/bot service needed)
# Bot token from @BotFather; chat ID of the managers' group.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGERS_CHAT_ID=

# Manager contact links shown to partners in the web UI footer
VITE_MANAGER_TELEGRAM_URL=https://t.me/your_manager
VITE_MANAGER_WHATSAPP_URL=https://wa.me/380000000000

# API base URL for the web app
VITE_API_BASE=/api
