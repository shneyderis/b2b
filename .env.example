# --- Postgres (Supabase) --------------------------------------------------
# DATABASE_URL: runtime pool used by the app. In production use the
# Supabase *Transaction Pooler* URL (port 6543, pgbouncer enabled) so that
# a burst of serverless invocations doesn't exhaust the Postgres
# max_connections limit (~60 on the free tier).
#
# Example (replace credentials/region):
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgres://user:pass@localhost:5432/winery

# DIRECT_DATABASE_URL: direct (non-pooled) connection used by migrate/seed.
# pgbouncer in transaction mode breaks some DDL operations and
# prepared-statement features, so schema changes and seeding must bypass it.
# In Supabase this is either the Direct Connection (port 5432) or the
# Session Pooler URL.
DIRECT_DATABASE_URL=postgres://user:pass@localhost:5432/winery

# --- Auth -----------------------------------------------------------------
JWT_SECRET=change-me

# --- Telegram ------------------------------------------------------------
# Outbound: partner / warehouse / managers notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGERS_CHAT_ID=
# Inbound webhook: only Telegram user IDs listed here can place orders
# through the bot. Comma-separated.
TELEGRAM_ADMIN_IDS=
# Secret sent by Telegram via the X-Telegram-Bot-Api-Secret-Token header
# so random POSTs to /api/telegram/webhook are rejected.
TELEGRAM_WEBHOOK_SECRET=

# --- Anthropic (freeform order text parsing, admin-only) ------------------
ANTHROPIC_API_KEY=

# --- Groq (voice-message transcription via Whisper, admin-only) -----------
# Used only when an admin sends a voice message to the bot. Empty disables
# voice and the bot replies with an error if a voice arrives.
GROQ_API_KEY=

# Base URL of the Mini App. The bot builds reply-keyboard web_app buttons
# for approved partners (Новий заказ, Мої замовлення, Профіль) that open
# this URL at /orders/new, /orders, /profile. Empty disables the keyboard.
# Also used as the origin for self-service password-reset links the bot
# sends to partners via Telegram DM (`<base>/reset-password?token=…`);
# without it, the token is created but the DM is skipped.
TELEGRAM_MINIAPP_URL=https://your.vercel.app

# --- Web (build-time / Vite) ----------------------------------------------
VITE_MANAGER_TELEGRAM_URL=https://t.me/your_manager
# Public URL of the Telegram bot (partners tap "Відкрити в Telegram" on the
# browser login page and land in the bot chat). Example:
# VITE_TELEGRAM_BOT_URL=https://t.me/beykushpartnerbot
VITE_TELEGRAM_BOT_URL=
VITE_API_BASE=/api
