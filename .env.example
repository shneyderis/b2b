# Postgres connection string (Supabase or local)
DATABASE_URL=postgres://user:pass@localhost:5432/winery

# JWT
JWT_SECRET=change-me

# Telegram bot for initData validation and notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGERS_CHAT_ID=

# SMTP (for email notifications, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public API base URL used by the web app
VITE_API_BASE=/api
